# =============================================================================
# EventShare environment template.
# Copy to ".env" and fill in real values. NEVER commit the real .env file.
# Docker Compose reads this file automatically.
# =============================================================================

# ---- Core URLs ----
APP_BASE_URL=https://eventshare.example.com
NEXT_PUBLIC_APP_BASE_URL=https://eventshare.example.com
NEXT_PUBLIC_API_BASE_URL=https://eventshare.example.com/api
CORS_ALLOWED_ORIGINS=https://eventshare.example.com

# ---- PostgreSQL ----
POSTGRES_DB=eventshare
POSTGRES_USER=eventshare
POSTGRES_PASSWORD=change-me-strong-db-password
# JDBC URL used by api + worker (host "postgres" is the compose service name)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/eventshare
SPRING_DATASOURCE_USERNAME=eventshare
SPRING_DATASOURCE_PASSWORD=change-me-strong-db-password

# ---- RabbitMQ ----
RABBITMQ_DEFAULT_USER=eventshare
RABBITMQ_DEFAULT_PASS=change-me-strong-mq-password
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=eventshare
SPRING_RABBITMQ_PASSWORD=change-me-strong-mq-password

# ---- Cloudflare R2 (S3-compatible object storage) ----
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=eventshare-media
# How long signed upload/download URLs stay valid (seconds)
R2_PRESIGN_UPLOAD_TTL_SECONDS=900
R2_PRESIGN_DOWNLOAD_TTL_SECONDS=3600

# ---- Clerk (authentication) ----
# Backend validates Clerk-issued JWTs via the JWKS endpoint.
# Issuer looks like https://<your-subdomain>.clerk.accounts.dev (or your custom domain).
CLERK_ISSUER=https://your-subdomain.clerk.accounts.dev
CLERK_JWKS_URL=https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json
# Optional: set if you configure an "aud" claim in your Clerk JWT template.
CLERK_AUDIENCE=
# Frontend Clerk keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- Media upload limits (enforced server-side) ----
MEDIA_MAX_UPLOAD_BYTES=524288000
MEDIA_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/heic,image/gif,video/mp4,video/quicktime,video/webm

# ---- Observability ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# ---- JVM tuning (api + worker) ----
JAVA_OPTS=-XX:MaxRAMPercentage=70 -XX:+UseG1GC

# ---- Platform administration ----
# Comma-separated emails granted ADMIN at provisioning time (JIT seeding).
ADMIN_EMAILS=admin@example.com

# ---- Stripe (V2 billing) ----
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Stripe Price IDs for each paid plan (create these in the Stripe dashboard)
STRIPE_PRICE_BASIC=price_replace_me
STRIPE_PRICE_WEDDING_PRO=price_replace_me
STRIPE_PRICE_LIFETIME=price_replace_me
BILLING_SUCCESS_URL=http://localhost/dashboard?billing=success
BILLING_CANCEL_URL=http://localhost/pricing?billing=cancel
